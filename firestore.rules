rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // Helper function to check if user is owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Products: Public read, Admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Profiles: Owner read/write, Admin read
    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Cart Items: Owner read/write
    match /cart_items/{itemId} {
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    // Orders: Owner create/read, Admin read/write
    match /orders/{orderId} {
      allow create: if request.auth != null; // Users create orders
      allow read: if isOwner(resource.data.user_id) || isAdmin();
      allow update: if isAdmin(); // Only admins update status
    }

    // Discount Codes: Public read (to apply), Admin write
    match /discount_codes/{codeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin Users:
    // 1. Allow checking own status (fixes the User's error)
    // 2. Allow creation if authenticated (needed for the client-side Secret Key signup to work)
    //    Note: In a real production app, this should be done via Cloud Functions or prevented.
    match /admin_users/{userId} {
      allow read: if isOwner(userId); 
      allow write: if isOwner(userId); 
    }
  }
}
